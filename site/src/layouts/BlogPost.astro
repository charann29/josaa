---
import BaseLayout from './BaseLayout.astro';
import { SITE, LINKS, PRICES } from '../consts';

interface Heading { depth: number; slug: string; text: string }
interface RelatedItem { slug: string; title: string; description: string }
interface Props {
  data: any;            // frontmatter
  slug: string;
  headings: Heading[];
  related: RelatedItem[];
  readingTime: number;
}
const { data, slug, headings, related, readingTime } = Astro.props;
const url = new URL(`/blog/${slug}`, SITE.url).href;
const seoTitle = data.seoTitle ?? `${data.title} | ${SITE.name}`;
const datePub = (data.pubDate instanceof Date ? data.pubDate : new Date(data.pubDate));
const dateMod = (data.updatedDate ? new Date(data.updatedDate) : datePub);
const toc = headings.filter((h) => h.depth === 2);

const articleLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: data.title,
  description: data.description,
  inLanguage: 'en-IN',
  datePublished: datePub.toISOString(),
  dateModified: dateMod.toISOString(),
  author: { '@type': 'Organization', name: data.author ?? SITE.name },
  publisher: {
    '@type': 'Organization',
    name: SITE.name,
    logo: { '@type': 'ImageObject', url: new URL('/logo.png', SITE.url).href },
  },
  mainEntityOfPage: { '@type': 'WebPage', '@id': url },
  image: new URL(data.ogImage ?? SITE.defaultOgImage, SITE.url).href,
  keywords: (data.keywords ?? []).join(', '),
};
const breadcrumbLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: SITE.url },
    { '@type': 'ListItem', position: 2, name: 'Blog', item: new URL('/blog', SITE.url).href },
    { '@type': 'ListItem', position: 3, name: data.title, item: url },
  ],
};
const faqLd = data.faqs?.length
  ? {
      '@context': 'https://schema.org',
      '@type': 'FAQPage',
      mainEntity: data.faqs.map((f: any) => ({
        '@type': 'Question',
        name: f.q,
        acceptedAnswer: { '@type': 'Answer', text: f.a },
      })),
    }
  : null;
---
<BaseLayout title={seoTitle} description={data.description} type="article" ogImage={data.ogImage}>
  <Fragment slot="head">
    <meta property="article:published_time" content={datePub.toISOString()} />
    <meta property="article:modified_time" content={dateMod.toISOString()} />
    <script type="application/ld+json" set:html={JSON.stringify(articleLd)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbLd)} />
    {faqLd && <script type="application/ld+json" set:html={JSON.stringify(faqLd)} />}
  </Fragment>

  <main class="container article">
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <a href="/">Home</a><span>/</span><a href="/blog">Blog</a><span>/</span>{data.title}
    </nav>

    <header class="article-head">
      <span class="tag">{data.theme.replace(/_/g, ' ')}</span>
      <h1>{data.title}</h1>
      <p class="dek">{data.description}</p>
      <div class="article-meta">
        <span>Updated {dateMod.toLocaleDateString('en-IN', { day: 'numeric', month: 'long', year: 'numeric' })}</span>
        <span>·</span>
        <span>{readingTime} min read</span>
        <span>·</span>
        <span>By {data.author}</span>
      </div>
    </header>

    {toc.length > 2 && (
      <nav class="toc" aria-label="Table of contents">
        <strong>On this page</strong>
        <ol>
          {toc.map((h) => <li><a href={`#${h.slug}`}>{h.text}</a></li>)}
        </ol>
      </nav>
    )}

    <article class="prose">
      <slot />
    </article>

    <div class="cta-box">
      <h3>Don't fill your JoSAA choices blind.</h3>
      <p>Get your full choice list, ordered from official 2023–2026 closing ranks for your exact rank, category &amp; quota.</p>
      <div class="row">
        <a href={LINKS.playbook} class="btn btn-amber"><svg class="ic"><use href="#i-list"/></svg>Get my list — {PRICES.playbook}</a>
        <a href={LINKS.call} class="btn btn-ghost" style="border-color:rgba(250,246,238,.3);color:var(--cream)"><svg class="ic"><use href="#i-cal"/></svg>1-hour call — {PRICES.call}</a>
      </div>
    </div>

    {data.faqs?.length > 0 && (
      <section class="faq-wrap">
        <h2 id="faq">Frequently asked questions</h2>
        {data.faqs.map((f: any) => (
          <details class="qa">
            <summary>{f.q}</summary>
            <div class="a" set:html={f.a} />
          </details>
        ))}
      </section>
    )}

    {related.length > 0 && (
      <section class="related">
        <h2>Keep reading</h2>
        <div class="related-grid">
          {related.map((r) => (
            <a href={`/blog/${r.slug}`}>
              <div class="t">{r.title}</div>
              <div class="d">{r.description}</div>
            </a>
          ))}
        </div>
      </section>
    )}
  </main>
</BaseLayout>
