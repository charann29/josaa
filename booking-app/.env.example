# ---- Razorpay (server) ----
# From Razorpay Dashboard → Settings → API Keys.
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# Same key id, exposed to the browser for the checkout widget.
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxx

# ---- Pricing ----
# Amount in paise. 299900 = ₹2,999. Decided server-side; the client cannot change it.
BOOKING_AMOUNT_PAISE=299900
BOOKING_CURRENCY=INR
NEXT_PUBLIC_AMOUNT_LABEL=₹2,999

# ---- Cal.com ----
# Your event link, the part after cal.com/  e.g. "beingwise/1-hour-call"
NEXT_PUBLIC_CAL_LINK=beingwise/1-hour-call

# ---- Security ----
# Secret for signing the short-lived "payment unlocked" token.
# Generate one: openssl rand -hex 32   (defaults to RAZORPAY_KEY_SECRET if unset)
BOOKING_TOKEN_SECRET=replace_with_a_long_random_string
