---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE, PRICES } from '../consts';

const toolLd = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'BeingWise Decision Copilot',
  applicationCategory: 'EducationApplication',
  operatingSystem: 'Web',
  url: new URL('/plan', SITE.url).href,
  description:
    'Build the exact ordered TS/AP EAMCET web-options list to freeze. A Decision Copilot orders your colleges Dream / Likely / Secure, flags every trade-off before you lock, and shows the official closing-rank data as proof.',
  offers: { '@type': 'Offer', price: '799', priceCurrency: 'INR' },
};
---
<BaseLayout
  title={`Decision Copilot — Build your TS/AP EAMCET web-options list | ${SITE.name}`}
  description="Enter your TS or AP EAMCET rank and category. The Decision Copilot builds the exact ordered list to freeze — Dream / Likely / Secure — drag to reorder, and it flags every web-options mistake before you lock."
  keywords="ts eamcet web options, ap eapcet web options, eamcet choice filling order, ts eamcet option entry, decision copilot, eamcet web options order, tg eapcet web options">
  <Fragment slot="head"><script type="application/ld+json" set:html={JSON.stringify(toolLd)} /></Fragment>

  <section class="container plan-intro">
    <span class="kicker"><svg class="ic"><use href="#i-chart"/></svg>TS &amp; AP EAMCET · web options</span>
    <h1>Build the exact list to freeze.</h1>
    <p>A predictor stops at “where might I get in.” The Copilot builds the ordered web-options list you should actually freeze — padded with a secure floor, and it stops you before every mistake that quietly costs a seat.</p>
  </section>

  <div class="container plan-page">
    <!-- COMMAND BAR -->
    <div class="cmd">
      <div class="lead serif">Tell me your rank — I’ll build the <b>exact list to freeze</b>, in the right order.</div>
      <div class="cmdrow">
        <div class="field rank"><label for="rank">EAMCET rank</label><input id="rank" type="number" value="18500" inputmode="numeric" min="1"></div>
        <div class="field"><label for="state">State</label><select id="state"><option value="TS">TS EAMCET</option><option value="AP">AP EAPCET</option></select></div>
        <div class="field"><label for="cat">Category</label><select id="cat"><option value="OC">OC</option><option value="BC_B">BC-B</option><option value="SC">SC</option></select></div>
        <div class="seg" id="seg" role="group" aria-label="Risk appetite"><button type="button" data-w="ambitious" aria-pressed="false">Ambitious</button><button type="button" data-w="balanced" class="on" aria-pressed="true">Balanced</button><button type="button" data-w="safe" aria-pressed="false">Cautious</button></div>
      </div>
      <button class="go" id="go" type="button"><span class="sp" aria-hidden="true"></span><span class="lbl">Build my plan</span></button>
    </div>

    <!-- APP BODY -->
    <div class="appbody">
      <div class="stage">
        <div class="think" id="think"></div>
        <div class="spectrum" id="spectrum">
          <div class="cap">Where <b>your rank</b> sits across reachable colleges</div>
          <div class="track" id="track"><div class="me" id="me"></div></div>
          <div class="scale"><span>a stretch (dream)</span><span>right for you</span><span>secure floor</span></div>
        </div>
        <div class="plan" id="plan"></div>
        <div class="lockbar" id="lockbar" style="display:none;"><button class="lockbtn" type="button" id="lockbtn">Lock my plan — final walk-through →</button></div>
      </div>
      <div class="rail">
        <div class="rh"><span class="av"></span><div class="rh-t"><b>Decision Copilot</b><div class="sub">talks through every move</div></div><span class="livepill"><i></i>live</span></div>
        <div class="feed" id="feed" role="log" aria-live="polite" aria-relevant="additions" aria-label="Decision Copilot messages"></div>
        <form class="askbar" id="askForm" autocomplete="off">
          <input class="i" id="ask" type="text" placeholder="Tell me what to change… e.g. “put CSE on top” or “add more secure colleges”" maxlength="200" />
          <button class="s" type="submit" aria-label="Send">↑</button>
        </form>
      </div>
    </div>

    <p class="prov"><b>Representative demo data.</b> Verified TS EAMCET 2024 anchors (CBIT 1,891 · VNR 2,008 · Vasavi 3,103 · MGIT 5,910 · CVR 6,590) plus representative tiers for other colleges. The same engine already processes 135,792 real allotment records — swap in full official TSCHE/APSCHE data and this is live. Not a guarantee; verify dates and rules on the official TS EAPCET / AP EAPCET portals.</p>

    <!-- PAYWALL (revealed after lock walk-through) -->
    <section class="paywall" id="paywall" style="display:none;">
      <div class="pw-l">
        <div class="lock">🔒</div>
        <h2>Your plan is ready.</h2>
        <p class="sub">Lock the exact order, get every college code, and re-optimise after each mock round.</p>
        <div class="count">⏳ Web options freeze soon. After that, nothing can change.</div>
        <div class="lockedlist">
          <div class="blur" id="pwList"></div>
          <div class="badge"><span id="pwBadge">🔒 Your full ordered list</span></div>
        </div>
      </div>
      <div class="pw-r">
        <div class="price hot">
          <div><div class="pl">Your plan + Copilot</div><div class="pd">Full ordered list, college codes, 1-click fill &amp; mock re-optimisation. You do it, guided.</div></div>
          <div class="pp">{PRICES.plan}</div>
        </div>
        <div class="price">
          <div><div class="pl">Done for you</div><div class="pd">We learn the student &amp; enter the options on the portal. You review &amp; freeze.</div></div>
          <div class="pp">{PRICES.doneForYou}</div>
        </div>
        <a class="btn btn-amber btn-block" href="/contact" id="unlockBtn">Unlock my plan — {PRICES.plan}</a>
        <p class="microtrust">🛡️ <b>Paid by you, never by colleges. Zero spam.</b> We never freeze your options — that final click is always yours.</p>
      </div>
    </section>
  </div>

  <style is:global>
    .plan-intro{padding:34px 0 6px}
    .plan-intro h1{font-size:2.1rem;margin:6px 0 8px}
    @media(min-width:760px){.plan-intro h1{font-size:2.7rem}}
    .plan-intro p{color:var(--ink-soft);max-width:46em;font-size:1.04rem}
    .plan-page{padding-top:14px;--reach:#c0492b;--likely:#2347f0;--safe:#2c6a47;
      --red-soft:#f8e6e0;--accent-soft:#eaeefe;--green-soft:#e4f0e8;--green-deep:#2c6a47;--red-deep:#9c3a22;--line2:rgba(16,23,42,.2)}

    .cmd{background:var(--paper);border:1px solid var(--line);border-radius:12px;padding:24px;margin-bottom:16px}
    .cmd .lead{font-size:1.3rem;font-weight:600;letter-spacing:-.02em;line-height:1.2;margin-bottom:18px}
    .cmd .lead b{color:var(--accent);font-weight:700}
    .cmdrow{display:grid;grid-template-columns:repeat(auto-fit,minmax(150px,1fr));gap:10px}
    .field{background:var(--paper);border:1px solid var(--line-strong);border-radius:10px;padding:9px 14px;min-height:56px;display:flex;flex-direction:column;justify-content:center}
    .field label{font-size:.62rem;font-weight:700;color:var(--ink-mute);letter-spacing:.1em;text-transform:uppercase;margin-bottom:2px}
    .field input,.field select{border:none;outline:none;font-family:inherit;font-size:1.02rem;font-weight:600;color:var(--ink);background:transparent;width:100%}
    .seg{display:flex;gap:4px;background:var(--cream-2);border:1px solid var(--line-strong);border-radius:10px;padding:4px;min-height:56px}
    .seg button{flex:1;border:none;background:transparent;font-family:inherit;font-size:.82rem;font-weight:600;color:var(--ink-mute);padding:0 10px;border-radius:7px;cursor:pointer;transition:.15s}
    .seg button.on{background:var(--ink);color:#fff}
    .go{width:100%;margin-top:12px;background:var(--accent);color:#fff;border:none;border-radius:10px;padding:14px;font-family:inherit;font-size:.95rem;font-weight:600;cursor:pointer;display:flex;align-items:center;justify-content:center;gap:9px;min-height:50px;transition:.16s}
    .go:hover{background:var(--accent-deep)}
    .go .sp{width:14px;height:14px;border:2px solid rgba(255,255,255,.4);border-top-color:#fff;border-radius:50%;display:none;animation:spin .7s linear infinite}
    .go.busy .sp{display:inline-block}.go.busy .lbl{opacity:.75}
    @keyframes spin{to{transform:rotate(360deg)}}

    .appbody{display:grid;grid-template-columns:1fr;background:var(--paper);border:1px solid var(--line);border-radius:12px;overflow:hidden;min-height:420px;box-shadow:var(--shadow)}
    @media(min-width:860px){.appbody{grid-template-columns:1fr 332px}}
    .stage{border-bottom:1px solid var(--line)}
    @media(min-width:860px){.stage{border-bottom:none;border-right:1px solid var(--line)}}
    .think{padding:22px 24px}
    .think .t{display:flex;align-items:center;gap:12px;font-size:.9rem;color:var(--ink-soft);padding:7px 0;opacity:0;transform:translateY(4px)}
    .think .t.show{opacity:1;transform:none;transition:.4s}
    .think .t .ic{width:21px;height:21px;border-radius:50%;border:2px solid var(--line2);display:flex;align-items:center;justify-content:center;font-size:11px;flex:0 0 auto}
    .think .t.done .ic{background:var(--green);border-color:var(--green);color:#fff}
    .think .t .dotmove{width:7px;height:7px;border-radius:50%;background:var(--accent);animation:dm .8s infinite}
    @keyframes dm{0%,100%{opacity:.3}50%{opacity:1}}
    .spectrum{padding:18px 24px 8px;opacity:0}
    .spectrum.show{opacity:1;transition:.5s}
    .spectrum .cap{font-size:.78rem;color:var(--ink-mute);font-weight:500;margin-bottom:34px}
    .spectrum .cap b{color:var(--ink);font-weight:600}
    .track{position:relative;height:6px;border-radius:99px;background:var(--cream-2);border:1px solid var(--line)}
    .track .me{position:absolute;top:-5px;width:2px;height:16px;background:var(--ink);border-radius:2px;transition:left 1s cubic-bezier(.2,.8,.2,1)}
    .track .me::after{content:"you";position:absolute;top:-15px;left:50%;transform:translateX(-50%);font-size:.58rem;font-weight:600;color:var(--ink);white-space:nowrap}
    .track .dot{position:absolute;top:-4px;width:13px;height:13px;border-radius:50%;background:#fff;border:2.5px solid var(--ink-mute);transition:left 1s cubic-bezier(.2,.8,.2,1);opacity:0}
    .scale{display:flex;justify-content:space-between;font-size:.64rem;color:var(--ink-mute);margin-top:14px;letter-spacing:.02em}
    .plan{padding:8px 16px}
    .zone{padding:16px 8px 4px;display:flex;align-items:baseline;justify-content:space-between}
    .zone .zl{font-family:'Geist',sans-serif;font-size:1.05rem;font-weight:600;display:flex;align-items:center;gap:9px}
    .zone .zl .zd{width:9px;height:9px;border-radius:50%}
    .zone .zl span{color:var(--ink-mute);font-weight:500;font-size:.78rem;font-family:'Geist'}
    .zone .zr{font-size:.62rem;color:var(--ink-mute);letter-spacing:.04em;text-transform:uppercase}
    .card{display:flex;align-items:center;gap:14px;border-radius:12px;padding:13px 16px;margin:8px;cursor:grab;background:var(--paper,#fff);border:1px solid var(--line);opacity:0;transform:translateY(10px) scale(.985);transition:box-shadow .18s,transform .18s,border-color .18s}
    .card.in{opacity:1;transform:none;transition:opacity .45s,transform .45s}
    .card.reach{background:#fcf3f1;border-color:rgba(192,73,43,.14)}
    .card.likely{background:#f2f4ff;border-color:rgba(35,71,240,.18)}
    .card.safe{background:#f4faf6;border-color:rgba(44,106,71,.18)}
    .card:hover{transform:translateY(-1px);box-shadow:0 10px 24px -18px rgba(16,23,42,.32)}
    .card.reach:hover{border-color:rgba(192,73,43,.45)}
    .card.likely:hover{border-color:rgba(35,71,240,.5)}
    .card.safe:hover{border-color:rgba(44,106,71,.45)}
    .card.drag{opacity:.4}
    .card.flash{animation:flash .9s}
    @keyframes flash{0%{box-shadow:0 0 0 0 rgba(35,71,240,.55)}100%{box-shadow:0 0 0 16px rgba(35,71,240,0)}}
    .move{display:flex;flex-direction:column;gap:3px}
    .mv{width:34px;height:26px;border:1.5px solid var(--line2);background:var(--paper,#fff);border-radius:8px;color:var(--ink-mute,#6b7385);font-size:10px;line-height:1;cursor:pointer;padding:0;touch-action:manipulation;transition:border-color .15s,background .15s}
    .mv:hover:not(:disabled){border-color:var(--ink-mute,#6b7385)}
    .mv:active:not(:disabled){background:var(--accent-soft,#eaeefe)}
    .mv:disabled{opacity:.3;cursor:default}
    .card .num{font-family:'Geist',sans-serif;font-weight:700;font-size:1.15rem;width:22px;text-align:center}
    .card .info{flex:1;min-width:0}
    .card .nm{font-weight:600;font-size:.98rem;letter-spacing:-.01em}
    .card .sub{font-size:.76rem;color:var(--ink-soft);margin-top:2px;display:flex;align-items:center;gap:8px}
    .conf{display:flex;flex-direction:column;align-items:flex-end;gap:5px;min-width:78px}
    .conf .pct{font-family:'Geist',sans-serif;font-size:1.15rem;font-weight:700}
    .conf .barbg{width:66px;height:5px;border-radius:99px;background:rgba(16,23,42,.1);overflow:hidden}
    .conf .bar{height:100%;border-radius:99px;width:0;transition:width .9s cubic-bezier(.2,.8,.2,1)}
    .conf .lab{font-size:.56rem;font-weight:700;letter-spacing:.08em;padding:2px 8px;border-radius:99px}
    .lockbar{padding:14px 16px 22px}
    .lockbtn{width:100%;background:var(--ink);color:var(--cream);border:none;border-radius:999px;padding:15px;font-family:'Geist';font-size:.95rem;font-weight:600;cursor:pointer;transition:.16s}
    .lockbtn:hover{transform:translateY(-2px)}

    .rail{background:linear-gradient(180deg,#fafbfc,#f1f3f6);display:flex;flex-direction:column}
    .rail .rh{display:flex;align-items:center;gap:11px;padding:15px 18px;border-bottom:1px solid var(--line);background:rgba(255,255,255,.55)}
    .rail .rh .av{width:34px;height:34px;border-radius:50%;background:radial-gradient(circle at 32% 30%,#6f8cff,#2347f0);position:relative;flex:0 0 auto;box-shadow:0 0 0 4px rgba(35,71,240,.12)}
    .rail .rh .av::after{content:"✦";position:absolute;inset:0;display:flex;align-items:center;justify-content:center;color:#fff;font-size:15px}
    .rail .rh .rh-t{flex:1;min-width:0}
    .rail .rh b{font-size:.92rem;letter-spacing:-.01em}.rail .rh .sub{font-size:.66rem;color:var(--ink-mute)}
    .livepill{display:inline-flex;align-items:center;gap:5px;font-size:.6rem;font-weight:700;letter-spacing:.06em;text-transform:uppercase;color:var(--green-deep);background:var(--green-soft);padding:4px 9px;border-radius:99px;flex:0 0 auto}
    .livepill i{width:6px;height:6px;border-radius:50%;background:var(--green);animation:lp 2s infinite}
    @keyframes lp{0%{box-shadow:0 0 0 0 rgba(63,138,95,.5)}70%{box-shadow:0 0 0 6px rgba(63,138,95,0)}100%{box-shadow:0 0 0 0 rgba(63,138,95,0)}}
    .feed{flex:1;padding:16px 16px 8px;display:flex;flex-direction:column;gap:11px;overflow-y:auto;max-height:462px}
    .feed::-webkit-scrollbar{width:0}
    .msg{position:relative;font-size:.83rem;line-height:1.55;border-radius:12px;padding:12px 14px 12px 40px;background:var(--paper);border:1px solid var(--line);box-shadow:0 1px 2px rgba(16,23,42,.03);opacity:0;transform:translateY(6px)}
    .msg.in{opacity:1;transform:none;transition:.4s}
    .msg b{font-weight:700;color:var(--ink)}
    .msg::before{content:"✦";position:absolute;left:11px;top:11px;width:20px;height:20px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:700;background:var(--accent-soft);color:var(--accent-deep)}
    .msg.good{background:#f4faf6;border-color:rgba(63,138,95,.25);color:#2f5e45}
    .msg.good::before{content:"✓";background:var(--green-soft);color:var(--green-deep)}
    .msg.warn{background:#f2f4ff;border-color:rgba(35,71,240,.32);color:#1c39c9}
    .msg.warn::before{content:"!";background:var(--accent-soft);color:var(--accent-deep)}
    .msg.alert{background:#fdf3f0;border-color:rgba(192,73,43,.28);color:var(--red-deep)}
    .msg.alert::before{content:"!";background:var(--red-soft);color:var(--red-deep)}
    .msg.ask .btns{display:flex;gap:8px;margin-top:12px}
    .msg.ask .btns span{flex:1;text-align:center;font-size:.78rem;font-weight:600;padding:10px;border-radius:10px;cursor:pointer;min-height:38px;display:flex;align-items:center;justify-content:center;transition:.15s}
    .msg.ask .btns .y{background:var(--ink);color:#fff}.msg.ask .btns .y:hover{background:#000}
    .msg.ask .btns .n{border:1.5px solid var(--line2);color:var(--ink-soft);background:var(--paper)}.msg.ask .btns .n:hover{border-color:var(--ink)}
    .caret{display:inline-block;width:7px;height:14px;background:var(--accent);margin-left:1px;vertical-align:-2px;animation:bl .8s steps(1) infinite}
    @keyframes bl{50%{opacity:0}}
    .askbar{padding:12px 14px;border-top:1px solid var(--line);background:rgba(255,255,255,.55);display:flex;gap:9px;align-items:center}
    .askbar .i{flex:1;min-width:0;font:inherit;font-size:.8rem;color:var(--ink);background:var(--paper);border:1px solid var(--line);border-radius:999px;padding:10px 14px;outline:none;transition:border-color .15s}
    .askbar .i:focus{border-color:var(--accent)}
    .askbar .i::placeholder{color:var(--ink-mute)}
    .askbar .s{flex:0 0 auto;width:36px;height:36px;border:none;border-radius:50%;background:var(--accent);color:#fff;display:flex;align-items:center;justify-content:center;font-size:15px;cursor:pointer;transition:.15s}
    .askbar .s:hover{background:var(--accent-deep);transform:translateY(-1px)}
    /* student message + thinking indicator */
    .msg.user{background:var(--ink);color:var(--cream);border-color:var(--ink);align-self:flex-end;max-width:88%;padding:10px 14px}
    .msg.user::before{display:none}
    .msg.user b{color:#fff}
    .msg.think{align-self:flex-start;padding:13px 16px}
    .msg.think::before{display:none}
    .dots3{display:inline-flex;gap:4px}
    .dots3 i{width:6px;height:6px;border-radius:50%;background:var(--accent);animation:d3 1s infinite}
    .dots3 i:nth-child(2){animation-delay:.15s}.dots3 i:nth-child(3){animation-delay:.3s}
    @keyframes d3{0%,100%{opacity:.3;transform:translateY(0)}50%{opacity:1;transform:translateY(-2px)}}
    .prov{font-size:.72rem;color:var(--ink-soft);line-height:1.55;padding:14px 2px;max-width:60em}
    .prov b{color:var(--ink)}

    /* paywall */
    .paywall{display:grid;grid-template-columns:1fr;gap:0;background:var(--paper);border:1px solid var(--line);border-radius:12px;overflow:hidden;margin:8px 0 10px}
    @media(min-width:780px){.paywall{grid-template-columns:1fr 1fr}}
    .pw-l{padding:34px 32px;border-bottom:1px solid var(--line)}
    @media(min-width:780px){.pw-l{border-bottom:none;border-right:1px solid var(--line)}}
    .pw-l .lock{font-size:30px;margin-bottom:8px}
    .pw-l h2{font-size:1.7rem;margin-bottom:6px}
    .pw-l .sub{color:var(--ink-mute);font-size:.95rem;line-height:1.5;margin-bottom:18px}
    .count{display:inline-flex;align-items:center;gap:8px;background:var(--red-soft);color:#b23a25;font-weight:600;font-size:.82rem;padding:10px 14px;border-radius:11px;margin-bottom:18px}
    .lockedlist{position:relative}
    .lockedlist .blur{filter:blur(5px);opacity:.55;pointer-events:none}
    .lockedlist .badge{position:absolute;inset:0;display:flex;align-items:center;justify-content:center}
    .lockedlist .badge span{background:var(--ink);color:#fff;font-size:.82rem;font-weight:600;padding:9px 16px;border-radius:99px}
    .miniRow{display:flex;justify-content:space-between;padding:10px 0;border-bottom:1px solid var(--line);font-size:.9rem}
    .pw-r{padding:34px 32px;display:flex;flex-direction:column;justify-content:center}
    .price{border:1.5px solid var(--line2);border-radius:16px;padding:18px;margin-bottom:12px;display:flex;align-items:center;justify-content:space-between;gap:14px}
    .price.hot{border-color:var(--accent);background:var(--accent-soft)}
    .price .pl{font-weight:700;font-size:1rem}
    .price .pd{color:var(--ink-mute);font-size:.78rem;margin-top:3px;max-width:230px;line-height:1.45}
    .price .pp{font-weight:800;font-size:1.35rem;font-family:'Geist',sans-serif}
    .btn-block{width:100%;margin-top:6px}
    .microtrust{display:flex;gap:8px;align-items:flex-start;margin-top:14px;color:var(--ink-mute);font-size:.78rem;line-height:1.5}

    /* keyboard focus — visible ring for keyboard users, none for mouse */
    .cmd input:focus-visible,.cmd select:focus-visible,.seg button:focus-visible,.go:focus-visible,
    .lockbtn:focus-visible,.mv:focus-visible,.askbar .i:focus-visible,.askbar .s:focus-visible,
    .msg.ask .btns span:focus-visible,.btn:focus-visible{outline:2px solid var(--accent-deep);outline-offset:2px}
    .card:focus-visible{outline:2px solid var(--accent-deep);outline-offset:-2px}
    .go[aria-busy="true"]{cursor:progress}

    /* reduced motion — instant, no choreography (JS timings collapse via RM flag) */
    @media (prefers-reduced-motion: reduce){
      *,*::before,*::after{animation-duration:.001ms!important;animation-iteration-count:1!important;transition-duration:.001ms!important}
      .card{opacity:1!important;transform:none!important}
      .spectrum{opacity:1!important}
      .think .t{opacity:1!important;transform:none!important}
      .msg{opacity:1!important;transform:none!important}
    }

    /* ---- mobile ---- */
    @media(max-width:600px){
      .plan-intro{padding:24px 0 4px}
      .plan-intro h1{font-size:1.65rem}
      .plan-intro p{font-size:.98rem}
      .cmd{padding:18px 15px}
      .cmd .lead{font-size:1.15rem;margin-bottom:14px}
      .cmdrow{gap:9px}
      .field,.seg{min-width:100%;width:100%}
      .seg{justify-content:space-between}
      .seg button{flex:1;padding:9px 4px}
      .go{margin-left:0;width:100%;justify-content:center;padding:14px;min-height:48px}
      .plan{padding:4px 8px}
      .zone{padding:14px 6px 4px}
      .card{padding:11px 12px;gap:9px;margin:7px 4px}
      .card .num{width:16px;font-size:1rem}
      .card .nm{font-size:.92rem}
      .card .sub{font-size:.72rem}
      .card .conf{min-width:58px}
      .card .conf .pct{font-size:1rem}
      .card .conf .barbg{width:48px}
      .feed{max-height:none}
      .prov{padding:14px 4px}
      .paywall .pw-l,.paywall .pw-r{padding:24px 20px}
      .pw-l h2{font-size:1.45rem}
      .price{flex-wrap:wrap;gap:6px}
      .price .pp{font-size:1.25rem}
    }
  </style>

  <script is:inline>
    /* ---- representative TS/AP EAMCET sample (OC closing; BC_B/SC derived offsets) ---- */
    const RAW=[["CBIT","Computer Science",1891,11],["VNR VJIET","Computer Science",2008,10],["Vasavi College","Computer Science",3103,10],["Mahindra University","Computer Science",4200,12],["MGIT","Computer Science",5910,8],["CVR College","Computer Science",6590,8],["CBIT","Mechanical",9000,6],["GRIET","Computer Science",9200,7],["Vasavi College","EEE",11000,6],["KMIT","Computer Science",11000,7],["MGIT","ECE",12000,7],["BVRIT Narsapur","Computer Science",13500,7],["CVR College","ECE",13500,6],["SNIST","Computer Science",14800,7],["VBIT","Computer Science",17500,5],["MLRIT","Computer Science",19000,5],["Anurag University","Computer Science",21000,6],["CMR College","Computer Science",26000,5],["Geethanjali","Computer Science",31000,4],["Nalla Malla Reddy","Computer Science",41000,4],["St. Martin's","Computer Science",47000,4]];
    const DATA=RAW.map(([inst,branch,oc,lpa])=>({inst,branch,lpa,band:(lpa-1)+"–"+(lpa+1)+"L",close:{OC:oc,BC_B:Math.round(oc*1.18),SC:Math.round(oc*1.9)}}));
    const C={reach:"#c0492b",likely:"#2347f0",safe:"#2c6a47"},LABBG={reach:"rgba(192,73,43,.14)",likely:"rgba(35,71,240,.16)",safe:"rgba(44,106,71,.16)"},TXT={reach:"DREAM",likely:"LIKELY",safe:"SECURE"};
    const $=(s)=>document.querySelector(s);
    const RM=window.matchMedia&&window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    function reach(r,c){const x=r/c;if(x<=0.85)return"safe";if(x<=1.08)return"likely";if(x<=1.5)return"reach";return"out";}
    function conf(r,c){return Math.max(5,Math.min(99,Math.round((1.62-r/c)/(1.62-0.45)*100)));}
    function buildBand(rank,cat,w){
      const t=DATA.map(c=>({...c,cl:c.close[cat],tag:reach(rank,c.close[cat])})).filter(c=>c.tag!=="out");
      const R=t.filter(c=>c.tag==="reach").sort((a,b)=>a.cl-b.cl),L=t.filter(c=>c.tag==="likely").sort((a,b)=>a.cl-b.cl);
      let S=t.filter(c=>c.tag==="safe").sort((a,b)=>a.cl-b.cl);
      const rc=w==="ambitious"?5:w==="safe"?2:3,sf=w==="safe"?6:w==="ambitious"?3:4;
      return [...R.slice(0,rc),...L,...S.slice(0,Math.max(sf,3))];
    }
    let weight="balanced",ORDER=[],POOL=[],RANK=18500,CAT="OC",dragFrom=null,reviewTimer=null,reviewSeq=0;
    function sleep(ms){return new Promise(r=>setTimeout(r,RM?0:ms));}
    async function build(){
      RANK=Math.max(1,+$('#rank').value||1);CAT=$('#cat').value;
      const stateLbl=$('#state').value==="AP"?"AP EAPCET":"TS EAMCET";
      const go=$('#go');go.classList.add('busy');go.setAttribute('aria-busy','true');
      $('#spectrum').classList.remove('show');$('#plan').innerHTML="";$('#feed').innerHTML="";$('#lockbar').style.display="none";$('#paywall').style.display="none";
      const steps=["Reading your rank "+RANK.toLocaleString()+" ("+CAT+", "+stateLbl+")","Filtering colleges to your category & region","Pulling 3 years of official closing ranks","Building your dream → safe band","Checking nothing winnable is dropped, floor padded"];
      const tk=$('#think');tk.innerHTML="";
      for(let i=0;i<steps.length;i++){const d=document.createElement('div');d.className='t';d.innerHTML=`<span class="ic"><span class="dotmove"></span></span>${steps[i]}`;tk.appendChild(d);await sleep(60);d.classList.add('show');await sleep(300);d.classList.add('done');d.querySelector('.ic').innerHTML="✓";}
      await sleep(160);tk.innerHTML="";
      ORDER=buildBand(RANK,CAT,weight);
      POOL=DATA.map(c=>{const cl=c.close[CAT];return {inst:c.inst,branch:c.branch,close:cl,lpa:c.lpa,tag:reach(RANK,cl)};}).filter(c=>c.tag!=="out");
      go.classList.remove('busy');go.removeAttribute('aria-busy');
      renderSpectrum();renderPlan(true);$('#lockbar').style.display="block";await openingNarration();
    }
    function renderSpectrum(){
      const sp=$('#spectrum');sp.classList.add('show');
      const track=$('#track');track.querySelectorAll('.dot').forEach(d=>d.remove());
      const ranks=ORDER.map(c=>c.cl);const lo=Math.min(...ranks,RANK),hi=Math.max(...ranks,RANK);const pos=v=>((v-lo)/((hi-lo)||1))*100;
      ORDER.forEach((c,i)=>{const d=document.createElement('div');d.className='dot';d.style.borderColor=C[c.tag];track.appendChild(d);requestAnimationFrame(()=>{setTimeout(()=>{d.style.left=`calc(${pos(c.cl)}% - 7px)`;d.style.opacity=1;},60+i*40);});});
      const me=$('#me');setTimeout(()=>me.style.left=`calc(${pos(RANK)}% - 1.5px)`,80);
    }
    function zoneHead(tag,sub,n){const lbl={reach:"Dream",likely:"Likely",safe:"Secure"}[tag];return `<div class="zone"><div class="zl"><span class="zd" style="background:${C[tag]}"></span>${lbl} <span>${sub}</span></div><div class="zr">${n} option${n>1?'s':''}</div></div>`;}
    function renderPlan(animate){
      const plan=$('#plan');let html="",last=null,n=1;
      const subs={reach:"· closes better than you",likely:"· closes near you",safe:"· closes worse · your floor"};
      const counts={reach:0,likely:0,safe:0};ORDER.forEach(c=>counts[c.tag]++);
      ORDER.forEach((c)=>{
        if(c.tag!==last){html+=zoneHead(c.tag,subs[c.tag],counts[c.tag]);last=c.tag;}
        const pc=conf(RANK,c.cl);
        html+=`<div class="card ${c.tag}" draggable="true" data-i="${n-1}">
          <div class="move"><button type="button" class="mv up" data-i="${n-1}" aria-label="Move ${c.inst} up">▲</button><button type="button" class="mv dn" data-i="${n-1}" aria-label="Move ${c.inst} down">▼</button></div>
          <span class="num" style="color:${C[c.tag]}">${n}</span>
          <div class="info"><div class="nm">${c.inst}</div><div class="sub">${c.branch} · closes ~${c.cl.toLocaleString()}</div></div>
          <div class="conf"><div class="pct">${pc}%</div><div class="barbg"><div class="bar" data-w="${pc}" style="background:${C[c.tag]}"></div></div><div class="lab" style="color:${C[c.tag]};background:${LABBG[c.tag]}">${TXT[c.tag]}</div></div>
        </div>`;n++;
      });
      plan.innerHTML=html;
      const ups=plan.querySelectorAll('.mv.up'),dns=plan.querySelectorAll('.mv.dn');
      if(ups[0])ups[0].disabled=true; if(dns[dns.length-1])dns[dns.length-1].disabled=true;
      const cards=[...plan.querySelectorAll('.card')];
      cards.forEach((el,i)=>{
        if(animate)setTimeout(()=>el.classList.add('in'),120+i*70);else el.classList.add('in');
        setTimeout(()=>{const b=el.querySelector('.bar');b.style.width=b.dataset.w+'%';},(animate?120+i*70:0)+120);
        el.addEventListener('dragstart',()=>{dragFrom=+el.dataset.i;el.classList.add('drag');});
        el.addEventListener('dragend',()=>el.classList.remove('drag'));
        el.addEventListener('dragover',e=>e.preventDefault());
        el.addEventListener('drop',e=>{e.preventDefault();const to=+el.dataset.i;if(dragFrom===null||dragFrom===to)return;const m=ORDER.splice(dragFrom,1)[0];ORDER.splice(to,0,m);dragFrom=null;renderPlan(false);const card=document.querySelector(`.card[data-i="${to}"]`);if(card)card.classList.add('flash');reactToReorder(m,to);});
        // tap reorder (touch devices where HTML5 drag doesn't fire)
        el.querySelectorAll('.mv').forEach(btn=>btn.addEventListener('click',ev=>{
          ev.stopPropagation();
          const from=+btn.dataset.i, to=from+(btn.classList.contains('up')?-1:1);
          if(to<0||to>=ORDER.length)return;
          const m=ORDER.splice(from,1)[0];ORDER.splice(to,0,m);renderPlan(false);
          const card=document.querySelector(`.card[data-i="${to}"]`);if(card)card.classList.add('flash');
          reactToReorder(m,to);
        }));
      });
    }
    function bubble(cls){const f=$('#feed');const m=document.createElement('div');m.className='msg '+cls;f.appendChild(m);requestAnimationFrame(()=>m.classList.add('in'));f.scrollTop=f.scrollHeight;return m;}
    async function type(el,html){if(RM){el.innerHTML=html;el.parentElement.scrollTop=el.parentElement.scrollHeight;return;}el.innerHTML='<span class="caret"></span>';const tmp=document.createElement('div');tmp.innerHTML=html;const txt=tmp.textContent;let s="";for(let i=0;i<txt.length;i++){s+=txt[i];el.innerHTML=s+'<span class="caret"></span>';if(i%2===0)await sleep(8);el.parentElement.scrollTop=el.parentElement.scrollHeight;}el.innerHTML=html;}
    async function openingNarration(){
      const counts={reach:0,likely:0,safe:0};ORDER.forEach(c=>counts[c.tag]++);
      const m=bubble('good');await type(m,`Done. I built a band for rank <b>${RANK.toLocaleString()}</b>: <b>${counts.reach}</b> dream, <b>${counts.likely}</b> likely, <b>${counts.safe}</b> secure. Nothing winnable was dropped and your floor is padded — you won't end with nothing.`);
      await sleep(200);
      if(!counts.reach){const m2=bubble('');await type(m2,`Your rank is mid-tier in this set, so there are no long-shot dreams worth gambling on — I focused on strong likely picks and a deep secure floor.`);await sleep(160);}
      const m3=bubble('');await type(m3,`Drag any college to reorder — I'll react instantly and ask before anything risky. When you're ready, hit <b>Lock my plan</b> and I'll walk you through it.`);
    }
    function callAgent(mode,instruction){
      return fetch('/api/copilot',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({
        mode,instruction,
        current:ORDER.map(c=>({inst:c.inst,branch:c.branch,tag:c.tag,close:c.cl})),
        pool:POOL.map(c=>({inst:c.inst,branch:c.branch,tag:c.tag,close:c.close})),
        rank:RANK,category:CAT,state:$('#state').value
      })}).then(r=>r.json());
    }
    function reconcile(order){
      if(!Array.isArray(order)||!order.length) return null;
      const lookup={}; POOL.forEach(c=>{lookup[(c.inst+'|'+c.branch).toLowerCase()]=c;});
      const next=[],seen=new Set();
      order.forEach(o=>{const k=((o.inst||'')+'|'+(o.branch||'')).toLowerCase();const m=lookup[k];if(m&&!seen.has(k)){seen.add(k);next.push({inst:m.inst,branch:m.branch,lpa:m.lpa,cl:m.close,tag:reach(RANK,m.close)});}});
      return next.length?next:null;
    }
    function orderDiffers(a,b){ if(!a||!b||a.length!==b.length) return true; for(let i=0;i<a.length;i++){ if(a[i].inst!==b[i].inst||a[i].branch!==b[i].branch) return true; } return false; }
    function offerSuggestion(m,rec){
      m.classList.add('ask');
      m.insertAdjacentHTML('beforeend','<div class="btns"><span class="y" role="button" tabindex="0">Use your version</span><span class="n" role="button" tabindex="0">Keep mine</span></div>');
      const ys=m.querySelector('.y'),ns=m.querySelector('.n');
      const done=()=>{m.dataset.done=1;ys.setAttribute('aria-disabled','true');ns.setAttribute('aria-disabled','true');ys.style.opacity=ns.style.opacity=.5;};
      const apply=()=>{ if(m.dataset.done)return; done(); ORDER=rec; renderSpectrum(); renderPlan(true); const g=bubble('good'); g.textContent='Done — applied my recommended order.'; };
      const keep=()=>{ if(m.dataset.done)return; done(); const g=bubble(''); g.textContent='Okay — your order stands.'; };
      ys.addEventListener('click',apply); ns.addEventListener('click',keep);
      ys.addEventListener('keydown',e=>{if(e.key==='Enter'||e.key===' '){e.preventDefault();apply();}});
      ns.addEventListener('keydown',e=>{if(e.key==='Enter'||e.key===' '){e.preventDefault();keep();}});
    }
    // a manual drag / ▲▼ fires this; debounce so a flurry of moves yields one opinion
    function reactToReorder(c,to){ clearTimeout(reviewTimer); const note=`moved ${c.inst} (${c.branch}) to position ${to+1}`; reviewTimer=setTimeout(()=>reviewMove(note),650); }
    async function reviewMove(note){
      const seq=++reviewSeq;
      const think=bubble('think'); think.innerHTML='<span class="dots3"><i></i><i></i><i></i></span>';
      try{
        const data=await callAgent('review',note);
        if(seq!==reviewSeq){ think.remove(); return; }
        think.remove();
        const v=data.verdict||'good';
        const m=bubble(v==='bad'?'alert':v==='caution'?'warn':'good');
        await type(m, esc(data.message||'Noted.'));
        const rec=reconcile(data.order);
        if((v==='bad'||v==='caution')&&rec&&orderDiffers(rec,ORDER)) offerSuggestion(m,rec);
      }catch(e){ if(seq===reviewSeq) think.remove(); }
    }
    function showPaywall(){
      const list=ORDER.slice(0,5).map((c,i)=>`<div class="miniRow"><span>${i+1}. ${c.inst} — ${c.branch}</span><span style="color:${C[c.tag]}">${TXT[c.tag]}</span></div>`).join("");
      $('#pwList').innerHTML=list;
      $('#pwBadge').textContent=`🔒 Your full ordered list — ${ORDER.length} choices`;
      const pw=$('#paywall');pw.style.display="grid";pw.scrollIntoView({behavior:'smooth',block:'center'});
    }
    async function walkthrough(){
      const m0=bubble('');await type(m0,`Let's do a final check before you lock — I'll stop at anything that matters and ask you.`);await sleep(220);
      let flagged=false;
      for(let i=0;i<ORDER.length-1;i++){const a=ORDER[i],b=ORDER[i+1];
        if(a.tag==='safe'&&(b.tag==='reach'||b.tag==='likely')){flagged=true;const m=bubble('warn ask');await type(m,`#${i+1} <b>${a.inst}</b> is a secure backup sitting above <b>${b.inst}</b>, which you can still win. Okay to keep it here?`);m.innerHTML+=`<div class="btns"><span class="y">Okay</span><span class="n">Fix</span></div>`;await sleep(380);}}
      const safes=ORDER.filter(c=>c.tag==='safe').length;
      if(safes<2){flagged=true;const m=bubble('alert ask');await type(m,`You have only <b>${safes}</b> secure option below your rank. That's a thin floor. Add a couple so you never end with nothing — okay?`);m.innerHTML+=`<div class="btns"><span class="y">Add them</span><span class="n">Skip</span></div>`;await sleep(380);}
      const m=bubble('good');await type(m,flagged?`That's everything I'd flag. Once you're happy with each, you're ready to freeze on the portal — and remember, <b>that final freeze is always your click, never mine.</b>`:`Your order is clean — dream on top, a strong likely middle, and a padded secure floor. You're ready to freeze. <b>That final click is always yours, never mine.</b>`);
      await sleep(300);showPaywall();
    }
    function esc(s){const d=document.createElement('div');d.textContent=s==null?'':String(s);return d.innerHTML;}
    async function askCopilot(text){
      text=(text||'').trim(); if(!text) return;
      if(!ORDER.length){ const w=bubble('warn'); w.textContent='Build a plan first, then tell me how to change it.'; return; }
      const um=bubble('user'); um.textContent=text;
      const seq=++reviewSeq;   // an instruction supersedes any pending move-review
      const think=bubble('think'); think.innerHTML='<span class="dots3"><i></i><i></i><i></i></span>';
      try{
        const data=await callAgent('instruct',text);
        think.remove();
        const rec=reconcile(data.order);
        if(rec){ ORDER=rec; renderSpectrum(); renderPlan(true); }
        const v=data.verdict||'good';
        const gm=bubble(v==='bad'?'alert':v==='caution'?'warn':'good');
        await type(gm, esc(data.message||'Updated your list.'));
      }catch(e){
        think.remove();
        const em=bubble('alert'); em.textContent="I couldn't reach my brain just now — try again, or move the rows yourself.";
      }
    }
    $('#askForm').addEventListener('submit',e=>{e.preventDefault();const i=$('#ask');const v=i.value;i.value='';askCopilot(v);});
    $('#go').addEventListener('click',build);
    $('#lockbtn').addEventListener('click',walkthrough);
    $('#rank').addEventListener('keydown',e=>{if(e.key==='Enter')build();});
    document.querySelectorAll('#seg button').forEach(b=>b.addEventListener('click',()=>{document.querySelectorAll('#seg button').forEach(x=>{x.classList.remove('on');x.setAttribute('aria-pressed','false');});b.classList.add('on');b.setAttribute('aria-pressed','true');weight=b.dataset.w;build();}));
    // deep-link from landing: /plan?rank=18500&cat=OC&state=TS
    const p=new URLSearchParams(location.search);
    if(p.get('rank'))$('#rank').value=p.get('rank');
    if(p.get('cat')){const cv=p.get('cat');if([...$('#cat').options].some(o=>o.value===cv))$('#cat').value=cv;}
    if(p.get('state')){const sv=p.get('state');if([...$('#state').options].some(o=>o.value===sv))$('#state').value=sv;}
    build();
  </script>
</BaseLayout>
