---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { SITE } from '../../../consts';

export async function getStaticPaths() {
  const pageSize = 48;
  const all = (await getCollection('colleges')).sort((a, b) => a.data.name.localeCompare(b.data.name));
  const totalPages = Math.ceil(all.length / pageSize);
  const paths = [];
  for (let n = 2; n <= totalPages; n++) {
    paths.push({ params: { page: String(n) }, props: { items: all.slice((n - 1) * pageSize, n * pageSize), n, totalPages } });
  }
  return paths;
}
const { items, n, totalPages } = Astro.props;
---
<BaseLayout title={`Colleges in India — Page ${n} of ${totalPages} | ${SITE.name}`} description="Browse more colleges across India — courses, fees, admission, cutoffs and placements.">
  <section class="container hub-hero">
    <span class="kicker"><svg class="ic"><use href="#i-map"/></svg>Page {n} of {totalPages}</span>
    <h1>Colleges in India</h1>
  </section>
  <div class="container">
    <div class="post-grid">
      {items.map((p: any) => (
        <a class="post-card" href={`/colleges/${p.id}`}>
          {p.data.city && <span class="tag">{p.data.city}</span>}
          <h3>{p.data.name}</h3>
          <p>{p.data.description}</p>
          <span class="more">{p.data.rating ? `★ ${p.data.rating} · ` : ''}View details →</span>
        </a>
      ))}
    </div>
    <nav class="pager">
      <a href={n === 2 ? '/colleges' : `/colleges/page/${n - 1}`} class="btn btn-ghost">← Prev</a>
      <span>Page {n} of {totalPages}</span>
      {n < totalPages && <a href={`/colleges/page/${n + 1}`} class="btn btn-ghost">Next →</a>}
    </nav>
  </div>
</BaseLayout>
