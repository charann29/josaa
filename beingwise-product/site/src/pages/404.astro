---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Page not found | BeingWise" description="The page you're looking for moved or doesn't exist." noindex={true}>
  <main class="container" style="padding:80px 0;text-align:center">
    <h1 style="font-size:3rem">404</h1>
    <p style="color:var(--ink-soft);margin:12px 0 24px">That page moved or never existed. Try the JoSAA guides instead.</p>
    <a href="/blog" class="btn btn-amber">Browse JoSAA guides</a>
  </main>
</BaseLayout>
