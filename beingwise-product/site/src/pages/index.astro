    .how{padding:clamp(44px,6vw,72px) 0}
    .how h2{font-size:1.9rem;text-align:center;margin-bottom:30px;max-width:18em;margin-inline:auto}
    .steps{display:grid;grid-template-columns:1fr;gap:18px;max-width:760px;margin:0 auto}
    @media(min-width:680px){.steps{grid-template-columns:1fr 1fr}}
    .step{display:flex;gap:14px;align-items:flex-start}
    .step .s-no{flex:0 0 auto;width:34px;height:34px;border-radius:50%;background:var(--accent-soft,#eaeefe);color:var(--accent-deep,#1c39c9);font-weight:700;display:flex;align-items:center;justify-content:center;font-family:'Geist',sans-serif}
    .step h4{font-size:1.05rem;margin-bottom:3px}
    .step p{font-size:.9rem;color:var(--ink-soft,#3c4458);line-height:1.5}
    .how-cta{display:flex;gap:12px;justify-content:center;margin-top:32px;flex-wrap:wrap}

    .honest-wrap{padding:10px 0 40px}
    .honest{background:var(--ink);color:var(--cream);border-radius:14px;padding:clamp(28px,4vw,36px) clamp(22px,4vw,32px);text-align:center;max-width:820px;margin:0 auto}
    .honest .seal{width:44px;height:44px;border-radius:50%;background:rgba(15,118,110,.18);display:flex;align-items:center;justify-content:center;margin:0 auto 14px}
    .honest .seal .ic{width:22px;height:22px;color:var(--accent,#2347f0)}
    .honest h3{font-size:1.45rem;margin-bottom:10px}
    .honest p{color:rgba(251,250,248,.82);line-height:1.6;max-width:48em;margin:0 auto}
    .honest p b{color:var(--cream)}

    .band{background:var(--cream-2,#f3ecdf);padding:clamp(44px,6vw,72px) 0}
    .center{text-align:center}
    .band h2{font-size:1.65rem;max-width:24em;margin:6px auto 28px}
    .tiers{display:grid;grid-template-columns:1fr;gap:16px;max-width:760px;margin:0 auto}
    @media(min-width:720px){.tiers{grid-template-columns:1fr 1fr}}
    .tier{position:relative;background:var(--paper,#fff);border:1px solid var(--line);border-radius:14px;padding:26px}
    .tier.feature{border-color:var(--accent,#2347f0);box-shadow:0 8px 26px -22px rgba(15,118,110,.55)}
    .tier .flag{position:absolute;top:-12px;left:24px;background:var(--accent,#2347f0);color:#fff;font-size:.7rem;font-weight:700;letter-spacing:.06em;text-transform:uppercase;padding:5px 12px;border-radius:99px}
    .tname{font-weight:600;font-size:1.05rem}
    .price{display:flex;align-items:baseline;gap:8px;margin:6px 0 4px}
    .price .rs{font-size:2.2rem;font-weight:700}
    .price .per{color:var(--ink-mute,#6b7385);font-size:.85rem}
    .tier .who{color:var(--ink-soft,#3c4458);font-size:.9rem;margin-bottom:14px}
    .tier ul{list-style:none;padding:0;margin:0 0 18px;display:flex;flex-direction:column;gap:10px}
    .tier li{display:flex;gap:9px;font-size:.9rem;color:var(--ink-soft,#3c4458);line-height:1.4}
    .tier li .ic{flex:0 0 auto;width:16px;height:16px;color:var(--green,#3f8a5f);margin-top:2px}
    .tier .note{font-size:.78rem;color:var(--ink-mute,#6b7385);margin-top:10px;text-align:center}

    #faq{padding:clamp(44px,6vw,72px) 0}
    .faq{max-width:760px;margin:0 auto;display:flex;flex-direction:column;gap:10px}
    .qa{background:var(--paper,#fff);border:1px solid var(--line);border-radius:12px;padding:4px 18px}
    .qa summary{cursor:pointer;font-family:'Geist',sans-serif;font-size:1.08rem;font-weight:600;padding:14px 0;list-style:none}
    .qa summary::-webkit-details-marker{display:none}
    .qa[open] summary{color:var(--accent-deep,#1c39c9)}
    .qa p{padding:0 0 16px;color:var(--ink-soft,#3c4458);line-height:1.6}

    .final{padding:clamp(44px,5vw,60px) 0;text-align:center;background:var(--ink);color:var(--cream)}
    .final h2{font-size:2rem;max-width:18em;margin:8px auto 10px}
    .final p{color:rgba(251,250,248,.8);margin-bottom:16px;max-width:34em;margin-inline:auto}

    /* editorial line-breaking */
    .hero h1,.trap h2,.how h2,.band h2,#faq h2,.final h2,.honest h3,.diff h4,.show-copy h2{text-wrap:balance}
    .hero .sub,.trap .lead,.trapnote,.step p,.diff p,.honest p,.trap-list p,.show-lead{text-wrap:pretty}

    /* ---- mobile ---- */
    @media(max-width:600px){
      .hero{padding:26px 0 22px}
      .hero h1{font-size:2.15rem}
      .hero .sub{font-size:1.02rem}
      .trustrow{gap:8px 14px;margin-top:16px;font-size:.8rem}
      .rankbox{padding:18px}
      .rankbox input{font-size:1.4rem}
      .show{padding:38px 0}
      .show-copy h2{font-size:1.55rem}
      .phone{padding:12px;border-radius:18px}
      .opt-main b{font-size:.92rem}
      .tag{font-size:.66rem;padding:4px 7px}
      .trap h2{font-size:1.55rem}
      .how h2{font-size:1.5rem}
      .band h2{font-size:1.4rem}
      .honest h3{font-size:1.25rem}
      .final h2{font-size:1.55rem}
      .how-cta .btn{width:100%}
      .btn{min-height:48px}
    }
    /* very small phones: keep tag on its own line so names never clip */
    @media(max-width:360px){
      .opt-list li{grid-template-columns:auto 1fr;row-gap:6px}
      .opt-list .tag{grid-column:2;justify-self:start}
    }
  </style>

  <script is:inline>
    (function(){
      var seg=document.getElementById('stateSeg'), state='TS';
      seg.querySelectorAll('button').forEach(function(b){
        b.addEventListener('click',function(){
          seg.querySelectorAll('button').forEach(function(x){x.classList.remove('on');});
          b.classList.add('on'); state=b.dataset.s;
        });
      });
      document.getElementById('rankForm').addEventListener('submit',function(e){
        e.preventDefault();
        var r=Math.max(1, parseInt(document.getElementById('rk').value,10)||0);
        var c=document.getElementById('ct').value;
        if(state==='JOSAA'){ location.href='/predictor?rank='+r; return; }
        location.href='/plan?rank='+r+'&state='+state+'&cat='+c;
      });
    })();
  </script>
</BaseLayout>
