    .trap-wrap{display:grid;grid-template-columns:1fr;gap:28px}
    @media(min-width:900px){.trap-wrap{grid-template-columns:.85fr 1.15fr;gap:56px;align-items:start}.trap-thesis{position:sticky;top:90px}}
    .trap-list{list-style:none;margin:0;padding:0;border-top:1px solid var(--line)}
    .trap-list li{display:grid;grid-template-columns:2.2ch 1fr;gap:16px;padding:16px 2px;border-bottom:1px solid var(--line);align-items:baseline}
    .trap-list .n{font-family:'Geist',sans-serif;font-size:1.35rem;font-weight:700;color:var(--accent-deep,#1c39c9);line-height:1}
    .trap-list h4{font-size:1.04rem;margin:0 0 5px;line-height:1.25}
