---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE, PRICES } from '../consts';

// TS/AP EAMCET-first landing. beingWise is the *solver*, not a predictor:
// it builds the exact ordered web-options list to freeze and flags the
// mistakes that quietly decide a Telugu student's seat.

const serviceLd = {
  '@context': 'https://schema.org', '@type': 'Service',
  name: 'TS & AP EAMCET Web Options & JoSAA Choice-Filling Help',
  serviceType: 'Engineering admission web-options planning',
  provider: { '@type': 'Organization', name: SITE.name, url: SITE.url },
  areaServed: 'IN',
  audience: { '@type': 'Audience', audienceType: 'TS EAMCET, AP EAPCET & JoSAA aspirants' },
  description: 'BeingWise builds the exact ordered web-options list you should freeze on TS EAMCET, AP EAPCET and JoSAA, with a Decision Copilot that flags every mistake before you lock.',
  offers: [
    { '@type': 'Offer', name: 'Your plan + Copilot', price: '799', priceCurrency: 'INR', url: SITE.url + '/plan' },
    { '@type': 'Offer', name: 'Done for you', price: '3999', priceCurrency: 'INR', url: SITE.url + '/plan' },
  ],
};
const faqLd = {
  '@context': 'https://schema.org', '@type': 'FAQPage',
  mainEntity: [
    { '@type': 'Question', name: 'Is this a college predictor?', acceptedAnswer: { '@type': 'Answer', text: 'No. A predictor stops at "where might I get in." BeingWise is the solver — it builds the exact ordered web-options list you should freeze, padded with a safe floor, and flags every mistake before you lock. The free rank check is the starting point.' } },
    { '@type': 'Question', name: 'Why do web options matter more than my rank?', acceptedAnswer: { '@type': 'Answer', text: 'Two students with the same TS/AP EAMCET rank and category land in very different colleges purely because of the order they freeze their options. Allotment scans top-to-bottom and stops at the first match — so the order is the decision, not the rank.' } },
    { '@type': 'Question', name: 'Do you support both TS EAMCET and AP EAPCET?', acceptedAnswer: { '@type': 'Answer', text: 'Yes — TS EAMCET (TG EAPCET) and AP EAPCET, with category and local region (OU / AU / SVU) handled. JoSAA (NIT/IIIT/GFTI) is supported through our separate free predictor.' } },
    { '@type': 'Question', name: 'Do you ever freeze my options for me?', acceptedAnswer: { '@type': 'Answer', text: 'Never. We build and order the list and catch mistakes, but that final freeze on the official portal is always your click. We are paid by you, never by colleges, and we never sell your number.' } },
  ],
};
---
<BaseLayout
  title="BeingWise — Win the right TS/AP EAMCET & JoSAA seat, not just predict it"
  description="A predictor guesses where you might get in. BeingWise builds the exact ordered web-options list you should freeze for TS EAMCET, AP EAPCET & JoSAA — and a Decision Copilot flags every mistake before you lock."
  keywords="ts eamcet web options, ap eapcet web options, tg eapcet 2025, ts eamcet college predictor, ap eamcet college predictor, eamcet choice filling order, eamcet allotments, engineering colleges telangana, college directory ap telangana, josaa college predictor, mht-cet, eduvale">
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(serviceLd)} />
    <script type="application/ld+json" set:html={JSON.stringify(faqLd)} />
  </Fragment>

  <!-- HERO + FREE RANK CHECK -->
  <section class="hero">
    <div class="container hero-grid">
      <div class="hero-copy">
        <span class="eyebrow"><span class="pulse"></span>TS &amp; AP EAMCET · 2026 Counselling</span>
        <h1>Your rank is done.<br>Now win the <em>right seat.</em></h1>
        <p class="sub">A predictor guesses where you <em>might</em> get in. BeingWise builds the exact ordered list you should <b>freeze</b> — and stops you the moment you're about to make a mistake that costs a seat.</p>
        <div class="trustrow">
          <span><svg class="ic"><use href="#i-shield"/></svg>Never sells your number</span>
          <span><svg class="ic"><use href="#i-check"/></svg>Built for TS &amp; AP EAMCET</span>
          <span><svg class="ic"><use href="#i-check"/></svg>We never freeze for you</span>
        </div>
      </div>

      <form class="rankbox" id="rankForm">
        <span class="eyebrow">Free · no sign-up</span>
        <label for="rk">What was your EAMCET rank?</label>
        <input id="rk" type="number" inputmode="numeric" min="1" value="18500" required />
        <div class="seg" id="stateSeg">
          <button type="button" data-s="TS" class="on">TS EAMCET</button>
          <button type="button" data-s="AP">AP EAPCET</button>
          <button type="button" data-s="JOSAA">JoSAA</button>
        </div>
        <label for="ct" class="lbl2">Category</label>
        <select id="ct">
          <option value="OC">OC / General</option>
          <option value="BC_B">BC-B</option>
          <option value="SC">SC</option>
        </select>
        <button type="submit" class="btn btn-amber block">Show my colleges →</button>
        <p class="micro">No phone number. No spam. Ever.</p>
      </form>
    </div>
  </section>

  <!-- DATA PLACE vs SOLVER -->
  <section class="diffstrip-wrap">
    <div class="container diffstrip">
      <div class="diff l">
        <h4>📚 The data place <span class="muted">(e.g. EduVale)</span></h4>
        <p>Gives you 10 years of cutoffs and predictions — then leaves you to synthesise it and decide alone, on guesswork, in one irreversible click.</p>
      </div>
      <div class="diff win">
        <h4><svg class="ic"><use href="#i-spark"/></svg>BeingWise — the solver</h4>
        <p>Reads that data <em>for</em> you, builds the exact ordered list, catches the mistakes, and helps you fill the portal. The answer — with the official data right there as proof.</p>
      </div>
    </div>
  </section>

  <!-- THE WEB OPTIONS TRAP -->
  <section class="trap">
    <div class="container trap-wrap">
      <div class="trap-thesis">
        <h2>Your rank is the question.<br>Your web options are the answer.</h2>
        <p class="lead">Two students, same rank and category, end up in very different colleges — purely from how they fill and freeze.</p>
        <p class="trapnote">None of these are solved by a predictor. They're about the act of filling and freezing — order, region, category, timing, money. <b>That's the layer beingWise solves.</b></p>
      </div>
      <ul class="trap-list">
        <li><span class="n">01</span><div><h4>College-by-college, not one order</h4><p>Allotment scans top-to-bottom and stops at the first match. Group by college and a worse branch gets allotted before a better one sitting lower.</p></div></li>
        <li><span class="n">04</span><div><h4>A secure college above a reachable better one</h4><p>The system allots the secure one first and never looks below. You're locked into the backup while a winnable seat goes to someone else.</p></div></li>
        <li><span class="n">05</span><div><h4>No secure floor — only dream colleges</h4><p>Rank reaches none of them → zero allotment, and a scramble into spot rounds with leftover seats.</p></div></li>
        <li><span class="n">06</span><div><h4>Freezing too early</h4><p>Freeze locks editing — no reacting to the mock allotment. A mistake spotted a day later can't be fixed.</p></div></li>
        <li><span class="n">10</span><div><h4>The local-region blunder</h4><p>Ranking non-local (OU/AU/SVU) colleges high throws away your local-quota advantage — a worse seat, far from home.</p></div></li>
        <li><span class="n">12</span><div><h4>Management vs convener confusion</h4><p>Management-quota seats aren't fee-reimbursable. One panic click can cost a family lakhs it qualified to get back.</p></div></li>
      </ul>
    </div>
  </section>

  <!-- HOW IT WORKS -->
  <section class="how">
    <div class="container">
      <h2>From your rank to your seat.</h2>
      <div class="steps">
        <div class="step"><div class="s-no">1</div><div><h4>Free rank check</h4><p>Enter your rank — see the colleges within reach, marked Dream / Likely / Secure.</p></div></div>
        <div class="step"><div class="s-no">2</div><div><h4>Build your plan</h4><p>The Decision Copilot orders the exact list to freeze and flags every risky move.</p></div></div>
        <div class="step"><div class="s-no">3</div><div><h4>Fill the portal</h4><p>Get every college code, or 1-click fill — you review and freeze it yourself.</p></div></div>
        <div class="step"><div class="s-no">4</div><div><h4>We guide every round</h4><p>Mock, modify, allotment — we bring you back at each step till your final seat.</p></div></div>
      </div>
      <div class="how-cta"><a href="/plan" class="btn btn-amber">Build my plan →</a><a href="/predictor" class="btn btn-ghost">Free JoSAA rank check</a></div>
    </div>
  </section>

  <!-- HONESTY -->
  <section class="honest-wrap"><div class="container">
    <div class="honest">
      <div class="seal"><svg class="ic"><use href="#i-shield"/></svg></div>
      <h3>We will never promise a "guaranteed seat."</h3>
      <p>Anyone who does is running the exact scam that targets worried parents. No honest service controls allotment. What we promise is the correct list, the right order, and a co-pilot that catches mistakes — so you get the best seat your rank can truly reach. <b>Paid by you, never by colleges. The final freeze is always your click.</b></p>
    </div>
  </div></section>

  <!-- PRICING -->
  <section class="band" id="pricing">
    <div class="container">
      <h2 class="center">Less than one tuition class — for the rank you spent two years earning.</h2>
      <div class="tiers">
        <div class="tier feature">
          <span class="flag">Most popular</span>
          <div class="tname">Your plan + Copilot</div>
          <div class="price"><span class="rs serif">{PRICES.plan}</span><span class="per">one-time</span></div>
          <div class="who">You build and freeze it yourself — fully guided.</div>
          <ul>
            <li><svg class="ic"><use href="#i-check"/></svg>Full ordered web-options list for your rank, category &amp; region</li>
            <li><svg class="ic"><use href="#i-check"/></svg>Decision Copilot flags every mistake before you lock</li>
            <li><svg class="ic"><use href="#i-check"/></svg>All college &amp; branch codes + 1-click portal fill</li>
            <li><svg class="ic"><use href="#i-check"/></svg>Re-optimise after every mock round</li>
          </ul>
          <a href="/plan" class="btn btn-amber block">Build my plan →</a>
          <p class="note">Start free — pay only to unlock codes &amp; fill.</p>
        </div>
        <div class="tier">
          <div class="tname">Done for you</div>
          <div class="price"><span class="rs serif">{PRICES.doneForYou}</span><span class="per">we enter it</span></div>
          <div class="who">We learn the student and enter the options on the portal.</div>
          <ul>
            <li><svg class="ic"><use href="#i-check"/></svg>Everything in the plan, built with you</li>
            <li><svg class="ic"><use href="#i-check"/></svg>We type all your options in the right order</li>
            <li><svg class="ic"><use href="#i-check"/></svg>You review everything — and freeze it yourself</li>
            <li><svg class="ic"><use href="#i-check"/></svg>Round-by-round guidance to your seat</li>
          </ul>
          <a href="/contact" class="btn btn-dark block">Talk to us</a>
          <p class="note">⛔ We never freeze your options. That's always your click.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section id="faq">
    <div class="container">
      <h2 class="center">Straight answers.</h2>
      <div class="faq">
        <details class="qa"><summary>Is this a college predictor?</summary><p>No. A predictor stops at "where might I get in." BeingWise is the solver — it builds the exact ordered list you should freeze, padded with a safe floor, and flags every mistake before you lock. The free rank check is just the start.</p></details>
        <details class="qa"><summary>Why do web options matter more than my rank?</summary><p>Two students with the same EAMCET rank and category land in very different colleges purely from the order they freeze. Allotment scans top-to-bottom and stops at the first match — the order is the decision.</p></details>
        <details class="qa"><summary>Do you support both TS EAMCET and AP EAPCET?</summary><p>Yes — TS EAMCET (TG EAPCET) and AP EAPCET, with category and local region (OU / AU / SVU) handled. JoSAA (NIT/IIIT/GFTI) is supported via our separate free predictor.</p></details>
        <details class="qa"><summary>Do you ever freeze my options for me?</summary><p>Never. We build and order the list and catch mistakes, but that final freeze on the official portal is always your click. Paid by you, never by colleges — we never sell your number.</p></details>
      </div>
    </div>
  </section>

  <!-- FINAL -->
  <section class="final">
    <div class="container">
      <h2>Don't lose your rank in the week that decides it.</h2>
      <p>Build the exact list you should freeze, with a co-pilot watching for every mistake.</p>
      <div class="how-cta"><a href="/plan" class="btn btn-amber">Build my plan →</a></div>
    </div>
  </section>

  <style is:global>
    .hero{padding:clamp(44px,8vw,84px) 0 clamp(36px,5vw,52px)}
    .hero-grid{display:grid;grid-template-columns:1fr;gap:34px;align-items:center}
    @media(min-width:880px){.hero-grid{grid-template-columns:1.05fr .95fr;gap:56px}}
    .eyebrow{display:inline-flex;align-items:center;gap:9px;font-size:.72rem;font-weight:600;letter-spacing:.1em;text-transform:uppercase;color:var(--ink-mute,#6d6f78)}
    .eyebrow .pulse{width:7px;height:7px;border-radius:50%;background:var(--accent,#2347f0);box-shadow:0 0 0 0 rgba(35,71,240,.55);animation:hp 2.4s infinite}
    @keyframes hp{70%{box-shadow:0 0 0 6px rgba(35,71,240,0)}100%{box-shadow:0 0 0 0 rgba(35,71,240,0)}}
    .hero h1{font-size:clamp(2.6rem,8vw,4.2rem);line-height:1.02;margin:18px 0 18px;font-weight:700;letter-spacing:-.04em}
    .hero h1 em{color:var(--accent,#2347f0);font-style:normal}
    .hero .sub{font-size:clamp(1.04rem,2.4vw,1.18rem);color:var(--ink-soft,#45474f);max-width:32em;line-height:1.5;text-wrap:pretty}
    .hero .sub em{font-style:normal;color:var(--ink);font-weight:600}
    .trustrow{display:flex;gap:18px;margin-top:22px;font-size:.82rem;color:var(--ink-mute,#6b7385);flex-wrap:wrap}
    .trustrow span{display:flex;align-items:center;gap:6px}
    .trustrow .ic{width:15px;height:15px;color:var(--accent-deep,#1c39c9)}
    .rankbox{background:var(--paper,#fff);border:1px solid var(--line-strong);border-radius:12px;padding:clamp(22px,4vw,30px);box-shadow:var(--shadow-md)}
    .rankbox label{display:block;font-size:.82rem;font-weight:600;color:var(--ink-soft,#3c4458);margin:12px 0 6px}
    .rankbox .lbl2{margin-top:14px}
    .rankbox input,.rankbox select{width:100%;border:1.5px solid var(--line);border-radius:12px;font:inherit;font-weight:700;color:var(--ink);background:var(--paper,#fff);padding:13px 14px}
    .rankbox input{font-size:1.5rem;text-align:center}
    .seg{display:flex;gap:6px;margin-top:12px}
    .seg button{flex:1;padding:10px 4px;border:1.5px solid var(--line);background:var(--paper,#fff);border-radius:8px;font:inherit;font-size:.8rem;font-weight:600;color:var(--ink-mute,#6b7385);cursor:pointer}
    .seg button.on{background:var(--ink);color:var(--cream);border-color:var(--ink)}
    .block{width:100%;margin-top:16px}
    .rankbox .micro{text-align:center;font-size:.75rem;color:var(--ink-mute,#6b7385);margin-top:10px}

    .diffstrip-wrap{padding:8px 0 4px}
    .diffstrip{display:grid;grid-template-columns:1fr;border:1px solid var(--line);border-radius:12px;overflow:hidden}
    @media(min-width:720px){.diffstrip{grid-template-columns:1fr 1fr}}
    .diff{padding:26px 28px;background:var(--paper,#fff)}
    .diff.l{border-bottom:1px solid var(--line)}
    @media(min-width:720px){.diff.l{border-bottom:none;border-right:1px solid var(--line)}}
    .diff.win{background:var(--accent-soft,#eaeefe)}
    .diff h4{font-size:1rem;display:flex;align-items:center;gap:8px;margin-bottom:8px}
    .diff h4 .ic{width:18px;height:18px;color:var(--accent-deep,#1c39c9)}
    .diff .muted{color:var(--ink-mute,#6b7385);font-weight:500}
    .diff p{color:var(--ink-soft,#3c4458);font-size:.95rem;line-height:1.55}

    .trap{padding:72px 0;background:var(--cream-2,#f3ecdf)}
    .trap h2{font-size:1.9rem;line-height:1.12;margin:8px 0 10px}
    @media(min-width:760px){.trap h2{font-size:2.4rem}}
    .trap .lead{color:var(--ink-soft,#3c4458);margin-bottom:16px}
    .trap-wrap{display:grid;grid-template-columns:1fr;gap:30px}
    @media(min-width:900px){.trap-wrap{grid-template-columns:.85fr 1.15fr;gap:56px;align-items:start}.trap-thesis{position:sticky;top:90px}}
    .trap-list{list-style:none;margin:0;padding:0;border-top:1px solid var(--line)}
    .trap-list li{display:grid;grid-template-columns:2.4ch 1fr;gap:18px;padding:18px 2px;border-bottom:1px solid var(--line);align-items:baseline}
    .trap-list .n{font-family:'Geist',sans-serif;font-size:1.45rem;font-weight:700;color:var(--accent-deep,#1c39c9);line-height:1}
    .trap-list h4{font-size:1.06rem;margin:0 0 5px;line-height:1.25}
    .trap-list p{font-size:.92rem;color:var(--ink-soft,#3c4458);line-height:1.55}
    .trapnote{margin-top:24px;font-size:1.05rem;color:var(--ink-soft,#3c4458);max-width:46em}
    .trapnote b{color:var(--ink)}

    .how{padding:72px 0}
    .how h2{font-size:1.9rem;text-align:center;margin-bottom:30px}
    .steps{display:grid;grid-template-columns:1fr;gap:18px;max-width:760px;margin:0 auto}
    @media(min-width:680px){.steps{grid-template-columns:1fr 1fr}}
    .step{display:flex;gap:14px;align-items:flex-start}
    .step .s-no{flex:0 0 auto;width:34px;height:34px;border-radius:50%;background:var(--accent-soft,#fbeed3);color:var(--accent-deep,#1c39c9);font-weight:700;display:flex;align-items:center;justify-content:center;font-family:'Geist',sans-serif}
    .step h4{font-size:1.05rem;margin-bottom:3px}
    .step p{font-size:.9rem;color:var(--ink-soft,#3c4458);line-height:1.5}
    .how-cta{display:flex;gap:12px;justify-content:center;margin-top:34px;flex-wrap:wrap}

    .honest-wrap{padding:10px 0 40px}
    .honest{background:var(--ink);color:var(--cream);border-radius:12px;padding:36px 32px;text-align:center;max-width:820px;margin:0 auto}
    .honest .seal{width:44px;height:44px;border-radius:50%;background:rgba(35,71,240,.18);display:flex;align-items:center;justify-content:center;margin:0 auto 14px}
    .honest .seal .ic{width:22px;height:22px;color:var(--accent,#2347f0)}
    .honest h3{font-size:1.5rem;margin-bottom:10px}
    .honest p{color:rgba(251,250,248,.82);line-height:1.6;max-width:48em;margin:0 auto}
    .honest p b{color:var(--cream)}

    .band{background:var(--cream-2,#f3ecdf);padding:72px 0}
    .center{text-align:center}
    .band h2{font-size:1.7rem;max-width:24em;margin:6px auto 28px}
    .tiers{display:grid;grid-template-columns:1fr;gap:16px;max-width:760px;margin:0 auto}
    @media(min-width:720px){.tiers{grid-template-columns:1fr 1fr}}
    .tier{position:relative;background:var(--paper,#fff);border:1px solid var(--line);border-radius:12px;padding:26px}
    .tier.feature{border-color:var(--accent,#2347f0);box-shadow:0 8px 26px -22px rgba(35,71,240,.55)}
    .tier .flag{position:absolute;top:-12px;left:24px;background:var(--accent,#2347f0);color:#fff;font-size:.7rem;font-weight:700;letter-spacing:.06em;text-transform:uppercase;padding:5px 12px;border-radius:99px}
    .tname{font-weight:600;font-size:1.05rem}
    .price{display:flex;align-items:baseline;gap:8px;margin:6px 0 4px}
    .price .rs{font-size:2.2rem;font-weight:700}
    .price .per{color:var(--ink-mute,#6b7385);font-size:.85rem}
    .tier .who{color:var(--ink-soft,#3c4458);font-size:.9rem;margin-bottom:14px}
    .tier ul{list-style:none;padding:0;margin:0 0 18px;display:flex;flex-direction:column;gap:10px}
    .tier li{display:flex;gap:9px;font-size:.9rem;color:var(--ink-soft,#3c4458);line-height:1.4}
    .tier li .ic{flex:0 0 auto;width:16px;height:16px;color:var(--green,#3f8a5f);margin-top:2px}
    .tier .note{font-size:.78rem;color:var(--ink-mute,#6b7385);margin-top:10px;text-align:center}

    #faq{padding:72px 0}
    .faq{max-width:760px;margin:0 auto;display:flex;flex-direction:column;gap:10px}
    .qa{background:var(--paper,#fff);border:1px solid var(--line);border-radius:12px;padding:4px 18px}
    .qa summary{cursor:pointer;font-family:'Geist',sans-serif;font-size:1.12rem;font-weight:600;padding:14px 0;list-style:none}
    .qa summary::-webkit-details-marker{display:none}
    .qa[open] summary{color:var(--accent-deep,#1c39c9)}
    .qa p{padding:0 0 16px;color:var(--ink-soft,#3c4458);line-height:1.6}

    .final{padding:60px 0;text-align:center;background:var(--ink);color:var(--cream)}
    .final h2{font-size:2rem;max-width:18em;margin:8px auto 10px}
    .final p{color:rgba(251,250,248,.8);margin-bottom:8px}

    /* editorial line-breaking (DESIGN.md restraint) */
    .hero h1,.trap h2,.how h2,.band h2,#faq h2,.final h2,.honest h3,.diff h4{text-wrap:balance}
    .hero .sub,.trap .lead,.trapnote,.step p,.diff p,.honest p,.trap-list p{text-wrap:pretty}

    /* ---- mobile ---- */
    @media(max-width:600px){
      .hero{padding:30px 0 24px}
      .hero h1{font-size:2.05rem}
      .hero .sub{font-size:1rem}
      .trustrow{gap:10px 16px;margin-top:18px}
      .rankbox{padding:20px}
      .rankbox input{font-size:1.35rem}
      .trap{padding:42px 0}
      .trap h2{font-size:1.6rem}
      .how,.band,#faq{padding:42px 0}
      .how h2{font-size:1.55rem}
      .band h2{font-size:1.45rem}
      .honest{padding:28px 22px}
      .honest h3{font-size:1.3rem}
      .final{padding:46px 0}
      .final h2{font-size:1.6rem}
      .how-cta .btn{width:100%}
      .seg button{padding:11px 4px}
      .btn{min-height:48px}
    }
  </style>

  <script is:inline>
    (function(){
      var seg=document.getElementById('stateSeg'), state='TS';
      seg.querySelectorAll('button').forEach(function(b){
        b.addEventListener('click',function(){
          seg.querySelectorAll('button').forEach(function(x){x.classList.remove('on');});
          b.classList.add('on'); state=b.dataset.s;
        });
      });
      document.getElementById('rankForm').addEventListener('submit',function(e){
        e.preventDefault();
        var r=Math.max(1, parseInt(document.getElementById('rk').value,10)||0);
        var c=document.getElementById('ct').value;
        if(state==='JOSAA'){ location.href='/predictor?rank='+r; return; }
        location.href='/plan?rank='+r+'&state='+state+'&cat='+c;
      });
    })();
  </script>
</BaseLayout>
