import body from '../../_eduvale/ap-eapcet-predictor.body.html?raw';
import inlineJs from '../../_eduvale/ap-eapcet-predictor.inline.js?raw';
const title = "AP EAPCET College Predictor 2026 | Find Eligible Engineering Colleges in Andhra Pradesh";
