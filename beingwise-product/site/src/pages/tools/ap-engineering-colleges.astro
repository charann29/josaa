---
import BaseLayout from '../../layouts/BaseLayout.astro';
import headHtml from '../../_eduvale/ap-engineering-colleges.head.html?raw';
import body from '../../_eduvale/ap-engineering-colleges.body.html?raw';
import inlineJs from '../../_eduvale/ap-engineering-colleges.inline.js?raw';
const title = "AP EAPCET Top Engineering Colleges 2026 - Branch-wise Merit Closing Ranks | Andhra Pradesh";
const description = "Find the best engineering colleges in Andhra Pradesh ranked by AP EAPCET 2026 OC closing merit rank. Branch-wise cutoffs for CSE, ECE, Civil, Mechanical, IT and all engineering disciplines.";
---
<BaseLayout title={title} description={description} chrome={false}>
  <Fragment slot="head" set:html={headHtml} />
  <Fragment set:html={body} />
  <script is:inline set:html={inlineJs} />
</BaseLayout>
